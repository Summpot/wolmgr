# Backend
DATABASE_URL=sqlite:./wolmgr.sqlite3
BIND_ADDR=127.0.0.1:8787
PUBLIC_ORIGIN=http://127.0.0.1:8787

# Embedded MQTT broker used by the Rust backend and ESP32-S3 WOL broker
MQTT_BIND_ADDR=0.0.0.0:1883
MQTT_WS_BIND_ADDR=0.0.0.0:8083
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=wolmgr-backend
MQTT_TOPIC_PREFIX=wolmgr/wol
# Leave MQTT_URL unset to start the embedded broker and connect to ws://127.0.0.1:8083/mqtt.
# Set MQTT_URL only when using an external broker. Supported schemes: mqtt, mqtts, ws, wss.
# MQTT_URL=wss://mqtt.example.com/mqtt

# GitHub OAuth (optional)
# Callback URL: http://127.0.0.1:8787/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend dev server (optional; same-origin proxy is used by default)
PUBLIC_API_BASE_URL=
