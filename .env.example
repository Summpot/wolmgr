# Backend
DATABASE_URL=sqlite:./wolmgr.sqlite3
BIND_ADDR=127.0.0.1:8787
PUBLIC_ORIGIN=http://127.0.0.1:8787
STATIC_DIR=frontend/dist

# GitHub OAuth (optional)
# Callback URL: http://127.0.0.1:8787/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ESP32-S3 broker / automation token (optional but recommended)
BROKER_API_TOKEN=

# Frontend dev server (optional; same-origin proxy is used by default)
PUBLIC_API_BASE_URL=
